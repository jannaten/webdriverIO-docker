# EditorConfig — https://editorconfig.org
# Ensures consistent baseline settings across VS Code, IntelliJ, Vim, etc.
# Prettier handles deeper formatting; EditorConfig handles the basics.
root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
trim_trailing_whitespace = true
insert_final_newline = true

# Markdown: preserve intentional trailing spaces (two spaces = line break)
[*.md]
trim_trailing_whitespace = false

# YAML is indentation-sensitive — make it explicit
[*.{yml,yaml}]
indent_size = 2
