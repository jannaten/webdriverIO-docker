{
  "name": "webdriverio-docker-e2e",
  "version": "2.0.0",
  "description": "Professional E2E automation framework: WebdriverIO v9 + Selenium Grid 4 + Docker. Parallel cross-browser execution across Chrome and Firefox with Allure reporting.",
  "main": "wdio.conf.js",
  "scripts": {
    "test": "wdio run wdio.conf.js",
    "test:suite:auth": "wdio run wdio.conf.js --suite auth",
    "test:suite:ui": "wdio run wdio.conf.js --suite ui",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down --remove-orphans",
    "docker:test": "npm run docker:up && npm test; EXIT=$?; npm run docker:down; exit $EXIT",
    "report:generate": "allure generate allure-results --clean -o allure-report",
    "report:open": "allure open allure-report",
    "report": "npm run report:generate && npm run report:open",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.js": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,yml,yaml,md}": [
      "prettier --write"
    ]
  },
  "keywords": [
    "webdriverio",
    "wdio",
    "selenium",
    "selenium-grid",
    "docker",
    "e2e",
    "automation",
    "testing",
    "mocha",
    "allure"
  ],
  "author": "Jannaten Nayem",
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@wdio/allure-reporter": "^9.0.0",
    "@wdio/cli": "^9.0.0",
    "@wdio/local-runner": "^9.0.0",
    "@wdio/mocha-framework": "^9.0.0",
    "@wdio/spec-reporter": "^9.0.0",
    "allure-commandline": "^2.30.0",
    "eslint": "^9.0.0",
    "eslint-plugin-mocha": "^10.0.0",
    "eslint-plugin-wdio": "^9.0.0",
    "husky": "^9.0.0",
    "lint-staged": "^15.0.0",
    "prettier": "^3.0.0"
  },
  "overrides": {
    "serialize-javascript": "7.0.5"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
